# ================= OKX合约API客户端（适配合约交易） =================
class OKXFuturesAPIClient:
    def __init__(self, api_key, api_secret, passphrase, is_sim=True):
        # CCXT初始化（强制合约类型）
        self.okx_ccxt = ccxt.okx({
            'apiKey': api_key,
            'secret': api_secret,
            'password': passphrase,
            'enableRateLimit': True,
            'sandbox': is_sim,
            'proxies': PROXY_SETTINGS,
            'options': {'defaultType': 'swap'}  # 合约类型
        })
        self.okx_ccxt.load_markets()

        # 原生API配置
        self.api_key = api_key
        self.api_secret = api_secret
        self.passphrase = passphrase
        self.base_url = "https://www.okx.com"
        self.sim = is_sim

        # 初始化Session
        self.session = requests.Session()
        self.session.proxies = PROXY_SETTINGS
        self.session.timeout = 30
        self.session.headers.update({
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
            "Content-Type": "application/json",
            "Accept": "application/json",
            "OK-ACCESS-PASSPHRASE": self.passphrase
        })
        requests.packages.urllib3.disable_warnings()

    def _get_timestamp(self):
        """严格按OKX要求生成时间戳"""
        import time
        timestamp_ms = int(time.time() * 1000)
        dt = datetime.datetime.fromtimestamp(timestamp_ms / 1000, datetime.timezone.utc)
        return dt.strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] + 'Z'

    def _sign(self, timestamp, method, request_path, query_params=None, body=None):
        """严格按OKX V5合约API签名规范"""
        query_params = query_params or {}
        body = body or {}

        # 构建query string
        query_string = ''
        if query_params:
            sorted_items = sorted(query_params.items())
            query_string = '&'.join([f"{k}={v}" for k, v in sorted_items])

        # 构建body字符串
        body_string = ''
        if body and method == 'POST':
            body_string = json.dumps(body, separators=(',', ':'), ensure_ascii=False)

        # 构建签名字符串
        sign_string = f"{timestamp}{method.upper()}{request_path}"
        if query_string:
            sign_string += f"?{query_string}"
        sign_string += body_string

        # 加密签名
        try:
            sign_bytes = hmac.new(
                self.api_secret.encode('utf-8'),
                sign_string.encode('utf-8'),
                hashlib.sha256
            ).digest()
            return base64.b64encode(sign_bytes).decode('utf-8')
        except Exception as e:
            logging.error(f"签名生成失败: {str(e)}")
            return ""

    def request(self, method, request_path, params=None, data=None):
        """合约API请求核心方法"""
        method = method.upper()
        params = params or {}
        data = data or {}
        url = f"{self.base_url}{request_path}"

        # 生成签名
        timestamp = self._get_timestamp()
        signature = self._sign(timestamp, method, request_path, params, data)

        if not signature:
            logging.error("❌ 签名生成失败")
            return None

        # 构建请求头
        headers = {
            "OK-ACCESS-KEY": self.api_key,
            "OK-ACCESS-SIGN": signature,
            "OK-ACCESS-TIMESTAMP": timestamp,
            "OK-ACCESS-PASSPHRASE": self.passphrase,
            "Content-Type": "application/json",
            "x-simulated-trading": "1" if self.sim else "0"
        }

        # 构建URL
        if method == "GET" and params:
            sorted_params = sorted(params.items())
            query_string = '&'.join([f"{k}={v}" for k, v in sorted_params])
            url += f"?{query_string}"

        # 发送请求
        try:
            if method == "GET":
                response = self.session.get(url, headers=headers, verify=False)
            elif method == "POST":
                body_string = json.dumps(data, separators=(',', ':'), ensure_ascii=False)
                response = self.session.post(url, data=body_string, headers=headers, verify=False)
            else:
                return None

            # 处理响应
            response_text = response.text
            if response.status_code == 401:
                logging.error(f"❌ 401认证失败 | 响应: {response_text[:200]}")
                return None

            response.raise_for_status()
            result = json.loads(response_text)

            if result.get("code") != "0":
                logging.error(f"API业务错误 | 代码:{result['code']} | 消息:{result['msg']}")
                return None

            return result.get("data", [])
        except Exception as e:
            logging.error(f"API请求异常: {str(e)} | URL:{url}")
            return None

    # 获取合约实时价
    def get_ticker_price(self, symbol):
        try:
            ticker = self.okx_ccxt.fetch_ticker(symbol)
            return float(ticker['last'])
        except Exception as e:
            data = self.request("GET", "/api/v5/market/ticker", params={"instId": symbol, "instType": "SWAP"})
            return float(data[0]['last']) if data else 0.0

    # 获取合约账户余额（USDT保证金）
    def get_account_balance(self):
        try:
