        # 提取非零资产明细
        non_zero_assets = {}
        for coin, amount in balance['total'].items():
            if float(amount) > 0.000001:  # 过滤极小数值
                non_zero_assets[coin] = {
                    '总计': round(float(amount), 6),
                    '可用': round(float(balance['free'].get(coin, 0)), 6),
                    '已用': round(float(balance['used'].get(coin, 0)), 6)
                }

        # 打印非零资产
